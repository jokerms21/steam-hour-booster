CONFIG_PATH=./config.json
STEAM_DATA_DIRECTORY=./steam-data
TOKEN_STORAGE_DIRECTORY=./tokens
MONITOR_PORT=3000

# Optional: Basic Auth for GUI
# GUI_USERNAME=admin
# GUI_PASSWORD=your_secret_password

# Optional: Domain and SSL for HTTPS
# GUI_DOMAIN=boost.example.com
# GUI_CERT_FILE=./certs/fullchain.pem
# GUI_KEY_FILE=./certs/privkey.pem

# Optional: Telegram Bot for notifications and control
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Optional: Safety delay after kick before resuming boost (seconds, default 180, 0 to disable)
# KICKED_SAFETY_DELAY=180